# Doogster stack secrets — copy this to `.env` in ~/stack and fill in the real values.
# NEVER commit the real .env (it is gitignored). Keep these values in your password manager.

# Cloudflare Tunnel token
#   Cloudflare Zero Trust -> Networks -> Tunnels -> (your tunnel) -> copy the run token
CF_TUNNEL_TOKEN=replace-with-cloudflare-tunnel-token

# Beszel monitoring agent auth
#   From the Beszel UI when you add this system (Add System dialog)
BESZEL_TOKEN=replace-with-beszel-token
BESZEL_KEY=replace-with-beszel-public-key

# Wallabag "save to read later" — used by the news-feed /save endpoint.
#   In Wallabag: Developer -> Create a new client -> copy client id + secret.
#   USERNAME/PASSWORD are your Wallabag login (change the default wallabag/wallabag first).
WALLABAG_CLIENT_ID=replace-with-wallabag-client-id
WALLABAG_CLIENT_SECRET=replace-with-wallabag-client-secret
WALLABAG_USERNAME=replace-with-wallabag-username
WALLABAG_PASSWORD=replace-with-wallabag-password
