# restic backup config — install at /etc/restic/restic.env (chmod 600).
# None of these are highly sensitive except the ping URL; the repo *password*
# lives separately in /etc/restic/password (also chmod 600).

RESTIC_REPOSITORY=azure:linuxbackups:tcc-linux-vm1
RESTIC_PASSWORD_FILE=/etc/restic/password
AZURE_ACCOUNT_NAME=tcc3cxbackups

# Optional Healthchecks.io dead-man's-switch. Create a free check (period 1 day,
# grace a few hours) and paste its ping URL here. Blank = pinging disabled.
HEALTHCHECK_URL=
